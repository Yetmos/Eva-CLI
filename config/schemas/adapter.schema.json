{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eva-cli.local/schemas/adapter.schema.json",
  "title": "Eva Adapter manifest",
  "$comment": "Schema for external, skill, MCP, and hardware adapter manifests. / 外部、Skill、MCP 和硬件 Adapter manifest 的 schema。",
  "type": "object",
  "required": ["id", "name", "version", "enabled", "transport", "capabilities", "permissions", "limits", "routing"],
  "properties": {
    "id": { "$comment": "Stable adapter id used by routing and policy allowlists. / 路由和策略白名单使用的稳定 Adapter ID。", "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$" },
    "name": { "$comment": "Human-readable adapter name. / 便于人工识别的 Adapter 名称。", "type": "string" },
    "version": { "$comment": "Manifest version for compatibility checks. / 用于兼容性检查的 manifest 版本。", "type": "string" },
    "enabled": { "$comment": "Whether this adapter can be registered. / 是否允许注册此 Adapter。", "type": "boolean" },
    "transport": {
      "$comment": "Adapter transport implementation. / Adapter transport 实现类型。",
      "type": "string",
      "enum": ["builtin", "stdio", "http", "eventbus", "mcp", "skill", "hardware", "lua_capability"]
    },
    "capabilities": { "$comment": "Capabilities exposed through this adapter. / 通过此 Adapter 暴露的能力。", "type": "array", "items": { "type": "string" } },
    "permissions": { "$comment": "Permission boundary for adapter execution. / Adapter 执行权限边界。", "type": "object" },
    "supervision": {
      "$comment": "Provider restart and run-as declaration; enforcement is owned by later W3 runtime stages. / Provider 重启与运行身份声明；实际执行由后续 W3 runtime 阶段负责。",
      "type": "object",
      "properties": {
        "restart": {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": { "type": "string", "enum": ["none", "on_failure", "always"] },
            "max_attempts": { "type": "integer" },
            "backoff_ms": { "type": "integer" }
          },
          "additionalProperties": false
        },
        "run_as": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "enum": ["current", "unix", "windows"] },
            "uid": { "type": "integer" },
            "gid": { "type": "integer" },
            "account": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "credentials": {
      "$comment": "Vault references mapped to explicitly allowed provider environment targets. / 映射到显式允许环境变量目标的 Vault 引用。",
      "type": "object",
      "properties": {
        "vault": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["env", "ref"],
            "properties": {
              "env": { "type": "string" },
              "ref": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "mcp": {
      "$comment": "MCP server launch or HTTP endpoint settings. / MCP server 启动或 HTTP endpoint 设置。",
      "type": "object",
      "properties": {
        "server_transport": { "$comment": "Use streamable_http for new HTTP manifests; http is a legacy alias. / 新 HTTP manifest 使用 streamable_http；http 为兼容别名。", "type": "string", "enum": ["stdio", "http", "streamable_http"] },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "endpoint": { "type": "string" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "http": {
          "$comment": "Streamable HTTP trust, client-auth, redirect, and origin policy. / Streamable HTTP 信任、客户端认证、重定向与 origin 策略。",
          "type": "object",
          "properties": {
            "trust_roots": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
            "client_auth": {
              "oneOf": [
                { "type": "string", "enum": ["none"] },
                {
                  "type": "object",
                  "required": ["cert_ref", "key_ref"],
                  "properties": {
                    "cert_ref": { "type": "string" },
                    "key_ref": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "redirect": {
              "oneOf": [
                { "type": "string", "enum": ["deny", "same_origin"] },
                {
                  "type": "object",
                  "required": ["mode"],
                  "properties": {
                    "mode": { "type": "string", "enum": ["deny", "same_origin"] },
                    "max_hops": { "type": "integer", "minimum": 0, "maximum": 10 }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "allowed_origins": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
          },
          "additionalProperties": false
        },
        "tool_allowlist": { "type": "array", "items": { "type": "string" } },
        "resource_allowlist": { "type": "array", "items": { "type": "string" } },
        "prompt_allowlist": { "type": "array", "items": { "type": "string" } }
      },
      "allOf": [
        {
          "if": {
            "properties": { "server_transport": { "const": "stdio" } }
          },
          "then": {
            "required": ["command"],
            "not": {
              "anyOf": [
                { "required": ["endpoint"] },
                { "required": ["headers"] },
                { "required": ["http"] }
              ]
            }
          }
        },
        {
          "if": {
            "required": ["server_transport"],
            "properties": {
              "server_transport": { "enum": ["http", "streamable_http"] }
            }
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["command"] },
                { "required": ["args"] }
              ]
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "limits": { "$comment": "Runtime limits for this adapter. / 此 Adapter 的运行限制。", "type": "object" },
    "routing": { "$comment": "Routing preferences for capability selection. / 能力选择时的路由偏好。", "type": "object" }
  },
  "additionalProperties": true
}
