{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eva-cli.local/schemas/agent.schema.json",
  "title": "Eva Agent manifest",
  "type": "object",
  "required": ["id", "enabled", "script", "subscriptions", "permissions"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$" },
    "enabled": { "type": "boolean" },
    "parent": { "type": "string" },
    "children": { "type": "array", "items": { "type": "string" } },
    "script": { "type": "string" },
    "script_version": { "type": "string" },
    "subscriptions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^/.+" }
    },
    "inbox": { "type": "object" },
    "timeout": { "type": "object" },
    "state": { "type": "object" },
    "permissions": { "type": "object" }
  },
  "additionalProperties": true
}
