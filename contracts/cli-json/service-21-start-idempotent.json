{
  "id": "service-start-idempotent",
  "description": "Repeated development start reports no mutation while already running.",
  "command": ["service", "start", "--dev", "--project", "<repo>", "--output", "json"],
  "process_exit_code": 0,
  "expected": {
    "ok": true,
    "command": "service.start",
    "exit_code": 0,
    "data": {
      "operation": "start",
      "state": "running",
      "mutation_executed": false,
      "production_adapter": false,
      "audit": [
        "mutation.policy:service.start:allow",
        "service_manager.mutation_executed:false"
      ]
    },
    "trace": {
      "span_id": "cli.service.start"
    }
  }
}
