{
  "id": "service-install",
  "description": "Development service install exposes stable mutation evidence without claiming production integration.",
  "command": ["service", "install", "--dev", "--project", "<repo>", "--output", "json"],
  "process_exit_code": 0,
  "expected": {
    "ok": true,
    "command": "service.install",
    "exit_code": 0,
    "data": {
      "kind": "fake",
      "service_name": "eva-dev",
      "operation": "install",
      "state": "stopped",
      "mutation_executed": true,
      "production_adapter": false,
      "audit": [
        "mutation.policy:service.install:allow",
        "service_manager.fake:install",
        "service_manager.mutation_executed:true"
      ]
    },
    "trace": {
      "span_id": "cli.service.install"
    }
  }
}
