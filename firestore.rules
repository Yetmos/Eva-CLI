rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isThreadMember(threadId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/threads/$(threadId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/threads/$(threadId)/members/$(request.auth.uid)).data.state == "active";
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create, update: if false;
      allow delete: if false;

      match /sessions/{threadId} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      match /notificationTokens/{tokenHash} {
        allow read: if isSelf(uid);
        allow write: if false;
      }
    }

    match /threads/{threadId} {
      allow read: if isThreadMember(threadId);
      allow write: if false;

      match /members/{uid} {
        allow read: if isThreadMember(threadId);
        allow write: if false;
      }

      match /messages/{messageId} {
        allow read: if isThreadMember(threadId);
        allow write: if false;
      }

      match /messageAudits/{messageId} {
        allow read, write: if false;
      }
    }

    match /invites/{tokenHash} {
      allow read, write: if false;
    }

    match /stickerPacks/{packId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /stickers/{stickerId} {
        allow read: if isSignedIn() && resource.data.enabled == true;
        allow write: if false;
      }
    }

    match /deletionJobs/{jobId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }
  }
}
